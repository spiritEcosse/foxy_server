{
  "version": 4,
  "configurePresets": [
    {
      "name": "base",
      "hidden": true,
      "generator": "Ninja",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "CMAKE_C_COMPILER": "clang",
        "CMAKE_CXX_COMPILER": "clang++",
        "CMAKE_C_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_LAUNCHER": "ccache",
        "CMAKE_CXX_COMPILER_CLANG_SCAN_DEPS": "clang-scan-deps",
        "CMAKE_CXX_FLAGS": "-stdlib=libc++",
        "CMAKE_EXE_LINKER_FLAGS": "-stdlib=libc++ -lc++abi",
        "CPM_SOURCE_CACHE": "${sourceDir}/.cache/CPM"
      }
    },
    {
      "name": "ninja-debug",
      "displayName": "Ninja Debug",
      "description": "Debug build with tests",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Debug", "ENABLE_TESTS": "ON" }
    },
    {
      "name": "ninja-release",
      "displayName": "Ninja Release (dev)",
      "description": "Release build with tests — for development and CI",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release", "ENABLE_TESTS": "ON" }
    },
    {
      "name": "ninja-prod",
      "displayName": "Ninja Production",
      "description": "Optimised Release build — no tests",
      "inherits": "base",
      "binaryDir": "${sourceDir}/build/prod",
      "cacheVariables": { "CMAKE_BUILD_TYPE": "Release" }
    }
  ],
  "buildPresets": [
    { "name": "ninja-debug",   "configurePreset": "ninja-debug",   "jobs": 12 },
    { "name": "ninja-release", "configurePreset": "ninja-release", "jobs": 12 },
    { "name": "ninja-prod",    "configurePreset": "ninja-prod",    "jobs": 12 }
  ],
  "testPresets": [
    {
      "name": "ninja-debug",
      "configurePreset": "ninja-debug",
      "output": { "outputOnFailure": true },
      "execution": { "jobs": 1 }
    },
    {
      "name": "ninja-release",
      "inherits": "ninja-debug",
      "configurePreset": "ninja-release"
    }
  ]
}
