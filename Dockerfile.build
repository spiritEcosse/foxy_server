FROM silkeh/clang:21

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        cmake \
        git \
        libpq-dev \
        libssl-dev \
        ninja-build \
        pkg-config \
        zlib1g-dev \
        meson \
        uuid-dev \
    && rm -rf /var/lib/apt/lists/*
