# Runtime environment variables — loaded via direnv (.envrc) or:
#   export $(grep -v '^#' .env | grep -v '^$' | xargs)
#
# DB: no config needed locally — defaults to /var/run/postgresql, db=foxy, user=foxy
# Docker containers get PG_DB/PG_USER from docker-compose.yml

# CORS origins
FOXY_CLIENT=http://localhost:5173
FOXY_ADMIN=http://localhost:5174

# Pinterest
PINTEREST_API_HOST=https://api.pinterest.com
PINTEREST_BOARD_ID=
PINTEREST_REFRESH_TOKEN=
PINTEREST_CLIENT_ID=
PINTEREST_CLIENT_SECRET=

# YouTube
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=

# Twitter
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=
TWITTER_BEARER_TOKEN=

# Cloudinary / storage
APP_CLOUD_NAME=
APP_BUCKET_HOST=

# App
ENVIRONMENT=dev
